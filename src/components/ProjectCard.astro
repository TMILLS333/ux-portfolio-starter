---
interface Props {
  title: string;
  description: string;
  image: string;
  tags: string[];
  slug: string;
}

const { title, description, image, tags, slug } = Astro.props;
---

<article class="group">
  <a
    href={`/projects/${slug}`}
    class="block rounded-card overflow-hidden transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2"
    style={`
      background-color: var(--color-surface);
      border: 1px solid var(--color-border);
      --tw-ring-color: var(--color-accent);
      --tw-ring-offset-color: var(--color-bg);
    `}
  >
    <!-- Project image -->
    <div class="aspect-[16/10] overflow-hidden" style="background-color: var(--color-surface-elevated);">
      <img
        src={image}
        alt={`Screenshot of ${title} project`}
        class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-300"
        loading="lazy"
      />
    </div>

    <!-- Project info -->
    <div class="p-6">
      <h3
        class="font-display text-subheading transition-colors duration-200"
        style="color: var(--color-text);"
      >
        <span class="group-hover:text-gradient">{title}</span>
      </h3>

      <p
        class="mt-2 font-body text-body line-clamp-2"
        style="color: var(--color-text-muted);"
      >
        {description}
      </p>

      {tags.length > 0 && (
        <div class="mt-4 flex flex-wrap gap-2">
          {tags.map((tag) => (
            <span
              class="inline-block px-2.5 py-1 font-body text-tag rounded-tag"
              style={`
                background-color: var(--color-accent-subtle);
                color: var(--color-accent);
              `}
            >
              {tag}
            </span>
          ))}
        </div>
      )}
    </div>
  </a>
</article>

<style>
  article:hover a {
    box-shadow: var(--shadow-card-hover);
    border-color: var(--color-accent);
  }
</style>
