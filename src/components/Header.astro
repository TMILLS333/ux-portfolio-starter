---
import ThemeToggle from './ThemeToggle.astro';

const navLinks = [
  { href: '/', label: 'Work' },
  { href: '/about', label: 'About' },
];

const currentPath = Astro.url.pathname;
---

<header
  class="sticky top-0 z-50 border-b backdrop-blur-nav"
  style="background-color: rgba(var(--header-bg-rgb, 250, 250, 248), 0.85); border-color: var(--color-border);"
>
  <nav class="max-w-content mx-auto px-6 sm:px-10 h-20 flex items-center justify-between" aria-label="Main navigation">
    <!-- Site name / logo -->
    <a
      href="/"
      class="flex items-center gap-3 font-display text-subheading tracking-tight hover:opacity-70 transition-opacity"
      style="color: var(--color-text);"
    >
      <div
        id="logo-fog"
        class="w-8 h-8 rounded-full overflow-hidden flex-shrink-0"
        style="border: 2px solid var(--color-accent);"
      ></div>
      Tania Millan
    </a>

    <!-- Navigation links + theme toggle -->
    <ul class="flex items-center gap-8" role="list">
      {navLinks.map(({ href, label }) => {
        const isActive = currentPath === href || (href !== '/' && currentPath.startsWith(href));
        return (
          <li>
            <a
              href={href}
              class:list={[
                'magnetic nav-magnetic font-body text-caption tracking-wide uppercase',
                isActive
                  ? 'font-medium'
                  : '',
              ]}
              style={isActive ? 'color: var(--color-text);' : 'color: var(--color-text-muted);'}
              aria-current={isActive ? 'page' : undefined}
            >
              <span class="magnetic-inner">{label}</span>
            </a>
          </li>
        );
      })}
      <li>
        <ThemeToggle />
      </li>
    </ul>
  </nav>
</header>

<style>
  :global(.dark) header {
    --header-bg-rgb: 20, 20, 19;
  }
</style>
