---
const navLinks = [
  { href: '/', label: 'Work' },
  { href: '/about', label: 'About' },
];

const currentPath = Astro.url.pathname;
---

<header
  class="sticky top-0 z-50 border-b backdrop-blur-nav"
  style="background-color: rgba(var(--header-bg-rgb, 250, 250, 248), 0.85); border-color: var(--color-border);"
>
  <nav class="max-w-content mx-auto px-6 h-16 flex items-center justify-between" aria-label="Main navigation">
    <!-- Site name / logo -->
    <a
      href="/"
      class="font-display text-subheading tracking-tight hover:opacity-70 transition-opacity"
      style="color: var(--color-text);"
    >
      Your Name
    </a>

    <!-- Navigation links -->
    <ul class="flex items-center gap-8" role="list">
      {navLinks.map(({ href, label }) => {
        const isActive = currentPath === href || (href !== '/' && currentPath.startsWith(href));
        return (
          <li>
            <a
              href={href}
              class:list={[
                'font-body text-caption tracking-wide uppercase transition-colors',
                isActive
                  ? 'font-medium'
                  : 'hover:opacity-70',
              ]}
              style={isActive ? 'color: var(--color-text);' : 'color: var(--color-text-muted);'}
              aria-current={isActive ? 'page' : undefined}
            >
              {label}
            </a>
          </li>
        );
      })}
    </ul>
  </nav>
</header>

<style>
  @media (prefers-color-scheme: dark) {
    header {
      --header-bg-rgb: 20, 20, 19;
    }
  }
</style>
