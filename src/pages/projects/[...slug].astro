---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<BaseLayout
  title={`${project.data.title} — Your Name`}
  description={project.data.description}
  image={project.data.image}
  type="article"
>
  <article>
    <!-- Full-bleed hero image -->
    <div
      class="w-full aspect-[21/9] sm:aspect-[3/1] overflow-hidden"
      style="background-color: var(--color-surface-elevated);"
    >
      <img
        src={project.data.image}
        alt={`${project.data.title} project hero image`}
        class="w-full h-full object-cover"
      />
    </div>

    <!-- Project content -->
    <div class="max-w-content mx-auto px-6 pt-12 sm:pt-16 pb-20 sm:pb-30">
      <div class="max-w-2xl">
        <!-- Back link -->
        <a
          href="/"
          class="inline-flex items-center gap-2 font-body text-caption transition-opacity hover:opacity-70 mb-8"
          style="color: var(--color-text-muted);"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M19 12H5M12 19l-7-7 7-7" />
          </svg>
          Back to work
        </a>

        <!-- Title + meta -->
        <h1 class="font-display text-display-lg">
          {project.data.title}
        </h1>

        <p
          class="mt-4 font-body text-body-lg"
          style="color: var(--color-text-muted);"
        >
          {project.data.description}
        </p>

        <!-- Tags -->
        {project.data.tags.length > 0 && (
          <div class="mt-6 flex flex-wrap gap-2">
            {project.data.tags.map((tag: string) => (
              <span
                class="inline-block px-3 py-1 font-body text-tag rounded-tag"
                style={`
                  background-color: var(--color-accent-subtle);
                  color: var(--color-accent);
                `}
              >
                {tag}
              </span>
            ))}
          </div>
        )}

        <!-- Divider -->
        <hr class="my-12 border-0 h-px" style="background-color: var(--color-border);" />

        <!-- Markdown content -->
        <div class="prose">
          <Content />
        </div>
      </div>
    </div>
  </article>
</BaseLayout>

<style is:global>
  /* Prose styles for markdown content */
  .prose {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 1.125rem;
    line-height: 1.7;
    color: var(--color-text-muted);
  }
  .prose h2 {
    font-family: 'Satoshi', system-ui, sans-serif;
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-text);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    letter-spacing: -0.01em;
  }
  .prose h3 {
    font-family: 'Satoshi', system-ui, sans-serif;
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-text);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .prose p {
    margin-bottom: 1.25rem;
  }
  .prose ul, .prose ol {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }
  .prose li {
    margin-bottom: 0.5rem;
  }
  .prose ul li {
    list-style-type: disc;
  }
  .prose ol li {
    list-style-type: decimal;
  }
  .prose strong {
    color: var(--color-text);
    font-weight: 600;
  }
  .prose a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .prose a:hover {
    color: var(--color-accent-hover);
  }
  .prose img {
    border-radius: 12px;
    margin-top: 2rem;
    margin-bottom: 2rem;
  }
  .prose blockquote {
    border-left: 3px solid var(--color-accent);
    padding-left: 1.25rem;
    margin: 1.5rem 0;
    font-style: italic;
    color: var(--color-text-faint);
  }
  .prose code {
    font-family: 'JetBrains Mono', Consolas, monospace;
    font-size: 0.875em;
    padding: 0.15em 0.4em;
    border-radius: 4px;
    background-color: var(--color-surface-elevated);
  }
</style>
