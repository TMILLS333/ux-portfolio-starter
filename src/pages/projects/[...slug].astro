---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);

const allProjects = (await getCollection('projects'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const currentIndex = allProjects.findIndex(p => p.id === project.id);
const nextProject = allProjects[(currentIndex + 1) % allProjects.length];
---

<BaseLayout
  title={`${project.data.title} — Portfolio`}
  description={project.data.description}
  image={project.data.image}
  type="article"
>
  <article>
    <!-- Cinematic hero — full viewport with image -->
    <section class="relative h-[70vh] sm:h-[80vh] overflow-hidden">
      <img
        src={project.data.image}
        alt={`${project.data.title} project hero image`}
        class="absolute inset-0 w-full h-full object-cover"
        fetchpriority="high"
      />
      <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(0,0,0,0.75) 0%, rgba(0,0,0,0.05) 50%, rgba(0,0,0,0.15) 100%);"></div>

      <!-- Title overlay — bottom -->
      <div class="absolute bottom-0 left-0 right-0 z-10 px-6 sm:px-10 lg:px-20 pb-16 sm:pb-24">
        <div class="max-w-content mx-auto">
          {project.data.tags.length > 0 && (
            <div class="flex flex-wrap gap-3 mb-8 project-reveal" style="--delay: 0.1s;">
              {project.data.tags.map((tag: string) => (
                <span
                  class="inline-block px-4 py-1.5 font-body text-tag rounded-tag"
                  style="background: rgba(255,255,255,0.18); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); color: rgba(255,255,255,0.95); border: 1px solid rgba(255,255,255,0.25);"
                >
                  {tag}
                </span>
              ))}
            </div>
          )}
          <h1
            class="font-display leading-[1.05] tracking-[-0.03em] text-white project-reveal"
            style="font-size: clamp(36px, 6vw, 72px); --delay: 0.2s;"
          >
            {project.data.title}
          </h1>
          <p
            class="mt-5 font-body text-body-lg max-w-2xl leading-relaxed project-reveal"
            style="color: rgba(255,255,255,0.75); --delay: 0.3s;"
          >
            {project.data.description}
          </p>
        </div>
      </div>
    </section>

    <!-- Back link — outside hero, clean and readable -->
    <div
      class="sticky top-20 z-30 project-reveal"
      style="background-color: var(--color-bg); border-bottom: 1px solid var(--color-border); --delay: 0.35s;"
    >
      <div class="max-w-content mx-auto px-6 sm:px-10 lg:px-20 py-4">
        <a
          href="/"
          class="inline-flex items-center gap-2 font-body text-caption transition-all duration-300 hover:gap-3"
          style="color: var(--color-text-muted);"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M19 12H5M12 19l-7-7 7-7" />
          </svg>
          Back to work
        </a>
      </div>
    </div>

    <!-- Project content — editorial layout -->
    <section class="relative" style="background-color: var(--color-bg);">
      <div class="max-w-content mx-auto px-6 sm:px-10 lg:px-20 pt-24 sm:pt-40 pb-28 sm:pb-44">
        <div class="grid grid-cols-1 lg:grid-cols-[200px_1fr] gap-16 lg:gap-28">
          <!-- Sidebar — sticky metadata -->
          <aside class="lg:sticky lg:top-36 lg:self-start space-y-12 project-reveal" style="--delay: 0.4s;">
            <div>
              <p
                class="font-body text-[11px] font-semibold uppercase tracking-[0.2em] mb-4"
                style="color: var(--color-text-faint);"
              >Role</p>
              <p class="font-body text-body" style="color: var(--color-text-muted);">Lead UX Designer</p>
            </div>
            <div>
              <p
                class="font-body text-[11px] font-semibold uppercase tracking-[0.2em] mb-4"
                style="color: var(--color-text-faint);"
              >Date</p>
              <p class="font-body text-body" style="color: var(--color-text-muted);">
                {project.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long' })}
              </p>
            </div>
            <div>
              <p
                class="font-body text-[11px] font-semibold uppercase tracking-[0.2em] mb-4"
                style="color: var(--color-text-faint);"
              >Skills</p>
              <div class="flex flex-wrap gap-2">
                {project.data.tags.map((tag: string) => (
                  <span
                    class="inline-block px-2.5 py-1 font-body text-tag rounded-tag"
                    style="background-color: var(--color-accent-subtle); color: var(--color-accent);"
                  >
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          </aside>

          <!-- Main content -->
          <div class="prose project-reveal" style="--delay: 0.45s;">
            <Content />
          </div>
        </div>
      </div>

      <!-- Next project — full-width cinematic teaser -->
      <div style="border-top: 1px solid var(--color-border);">
        <a
          href={`/projects/${nextProject.id}`}
          class="group block"
        >
          <div class="max-w-content mx-auto px-6 sm:px-10 lg:px-20 py-28 sm:py-44">
            <p
              class="font-body text-[11px] font-semibold uppercase tracking-[0.2em] mb-16"
              style="color: var(--color-text-faint);"
            >Next project</p>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-20 items-center">
              <div>
                <h2
                  class="font-display leading-[1.05] tracking-[-0.02em] transition-colors duration-500 group-hover:text-[var(--color-accent)]"
                  style="font-size: clamp(36px, 5vw, 64px); color: var(--color-text);"
                >
                  {nextProject.data.title}
                </h2>
                <p
                  class="mt-6 font-body text-body-lg leading-relaxed max-w-md"
                  style="color: var(--color-text-muted);"
                >
                  {nextProject.data.description}
                </p>
                <div
                  class="mt-10 inline-flex items-center gap-2 font-body text-body font-medium transition-all duration-500 group-hover:gap-5"
                  style="color: var(--color-accent);"
                >
                  View project
                  <svg class="w-5 h-5 transition-transform duration-500 group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M5 12h14M12 5l7 7-7 7" />
                  </svg>
                </div>
              </div>
              <div
                class="overflow-hidden rounded-card aspect-[16/10] transition-all duration-500 group-hover:shadow-lg"
                style="border: 1px solid var(--color-border);"
              >
                <img
                  src={nextProject.data.image}
                  alt={`${nextProject.data.title} preview`}
                  class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.04]"
                />
              </div>
            </div>
          </div>
        </a>
      </div>
    </section>
  </article>
</BaseLayout>

<style>
  /* Staggered reveal animation for project page elements */
  .project-reveal {
    opacity: 0;
    transform: translateY(24px);
    animation: projectFadeIn 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: var(--delay, 0s);
  }

  @keyframes projectFadeIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .project-reveal {
      opacity: 1;
      transform: none;
      animation: none;
    }
  }
</style>


