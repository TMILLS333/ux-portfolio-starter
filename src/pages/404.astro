---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found — Your Name"
  description="The page you're looking for doesn't exist."
>
  <section class="max-w-3xl mx-auto px-4 sm:px-6 py-24 text-center">
    <h1 class="text-6xl font-bold text-gray-900">404</h1>
    <p class="mt-4 text-lg text-gray-600">
      This page doesn't exist. Maybe it was moved or you mistyped the URL.
    </p>
    <a
      href="/"
      class="mt-8 inline-flex items-center px-5 py-2.5 text-sm font-medium rounded-lg bg-primary-600 text-white hover:bg-primary-700 transition-colors"
    >
      Go home
    </a>
  </section>
</BaseLayout>
