---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout
  title="Your Name — UX Designer"
  description="UX designer crafting thoughtful, user-centered digital experiences. View my portfolio of mobile, web, and product design work."
>
  <!-- Hero Section -->
  <section class="max-w-content mx-auto px-6 pt-20 sm:pt-30 pb-16 sm:pb-24">
    <p
      class="font-body text-caption uppercase tracking-widest mb-4"
      style="color: var(--color-accent);"
    >
      UX Designer
    </p>
    <h1 class="font-display text-display-lg sm:text-display-xl max-w-3xl">
      Hi, I'm <span class="text-gradient">Your Name</span>
    </h1>
    <p
      class="mt-6 font-body text-body-lg max-w-2xl"
      style="color: var(--color-text-muted);"
    >
      I design intuitive, accessible digital experiences that solve real problems.
      Turning complex challenges into simple, elegant solutions.
    </p>
    <div class="mt-10 flex flex-wrap gap-4">
      <a
        href="#projects"
        class="inline-flex items-center px-6 py-3 font-body text-body font-medium rounded-button transition-colors"
        style={`
          background-color: var(--color-accent);
          color: var(--color-text-inverse);
        `}
      >
        View my work
        <svg class="ml-2 w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M7 17L17 7M17 7H7M17 7V17" />
        </svg>
      </a>
      <a
        href="/about"
        class="inline-flex items-center px-6 py-3 font-body text-body font-medium rounded-button border transition-colors"
        style={`
          border-color: var(--color-border);
          color: var(--color-text);
        `}
      >
        About me
      </a>
    </div>
  </section>

  <!-- Projects Section -->
  <section
    id="projects"
    class="max-w-content mx-auto px-6 pb-20 sm:pb-30"
    aria-labelledby="projects-heading"
  >
    <div class="flex items-center justify-between mb-10">
      <h2
        id="projects-heading"
        class="font-display text-heading"
      >
        Selected Work
      </h2>
      <span
        class="hidden sm:block font-body text-caption"
        style="color: var(--color-text-faint);"
      >
        {projects.length} projects
      </span>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {projects.map((project) => (
        <ProjectCard
          title={project.data.title}
          description={project.data.description}
          image={project.data.image}
          tags={project.data.tags}
          slug={project.id}
        />
      ))}
    </div>
  </section>

  <!-- Contact CTA -->
  <section
    class="border-t py-20 sm:py-30"
    style="border-color: var(--color-border);"
  >
    <div class="max-w-content mx-auto px-6 text-center">
      <h2 class="font-display text-display">
        Let's work together
      </h2>
      <p
        class="mt-4 font-body text-body-lg max-w-xl mx-auto"
        style="color: var(--color-text-muted);"
      >
        I'm always open to new opportunities and collaborations.
      </p>
      <a
        href="mailto:hello@example.com"
        class="inline-flex items-center mt-8 px-8 py-3 font-body text-body font-medium rounded-button transition-colors"
        style={`
          background-color: var(--color-accent);
          color: var(--color-text-inverse);
        `}
      >
        Get in touch
      </a>
    </div>
  </section>
</BaseLayout>
