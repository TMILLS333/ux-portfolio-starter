---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout
  title="Tania Millan — UX Designer"
  description="UX designer crafting thoughtful, user-centered digital experiences. View my portfolio of mobile, web, and product design work."
>
  <!-- Hero Section — Cinematic with subtle animated orbs -->
  <section class="snap-section relative overflow-hidden" id="hero">
    <!-- Subtle animated orbs on light bg -->
    <div class="hero-orb hero-orb-1"></div>
    <div class="hero-orb hero-orb-2"></div>
    <div class="hero-orb hero-orb-3"></div>

    <div class="max-w-content mx-auto px-6 sm:px-10 relative z-10 reveal-stagger reveal">
      <p
        class="reveal-child font-body text-caption uppercase tracking-[0.2em] mb-10"
        style="color: var(--color-accent);"
      >UX Designer</p>
      <h1
        class="reveal-child font-display leading-[1.0] tracking-[-0.03em] max-w-4xl"
        style="font-size: clamp(48px, 8vw, 96px);"
      >
        Crafting <em>intuitive</em><br>digital experiences
      </h1>
      <p
        class="reveal-child mt-10 font-body text-body-lg max-w-xl leading-relaxed"
        style="color: var(--color-text-muted);"
      >
        Turning complex challenges into simple, elegant solutions.
        I design interfaces that feel natural from the first interaction.
      </p>
      <div class="reveal-child mt-14 flex flex-wrap gap-5">
        <a
          href="#projects"
          class="magnetic btn-glow inline-flex items-center px-8 py-4 font-body text-body font-medium rounded-button transition-colors"
          style="background-color: var(--color-accent); color: var(--color-text-inverse);"
        >
          <span class="magnetic-inner inline-flex items-center">
            View my work
            <svg class="ml-2 w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M7 17L17 7M17 7H7M17 7V17" />
            </svg>
          </span>
        </a>
        <a
          href="/about"
          class="magnetic inline-flex items-center px-8 py-4 font-body text-body font-medium rounded-button border transition-colors"
          style="border-color: var(--color-border); color: var(--color-text);"
        >
          <span class="magnetic-inner">About me</span>
        </a>
      </div>
    </div>
  </section>

  <style>
    .hero-orb {
      position: absolute;
      border-radius: 50%;
      filter: blur(100px);
      pointer-events: none;
    }

    .hero-orb-1 {
      width: 600px;
      height: 600px;
      background: rgba(8, 145, 178, 0.08);
      top: -10%;
      right: -5%;
      animation: orb-drift-1 16s ease-in-out infinite;
    }

    .hero-orb-2 {
      width: 450px;
      height: 450px;
      background: rgba(6, 182, 212, 0.06);
      bottom: -15%;
      left: -5%;
      animation: orb-drift-2 20s ease-in-out infinite;
    }

    .hero-orb-3 {
      width: 300px;
      height: 300px;
      background: rgba(34, 211, 238, 0.05);
      top: 30%;
      left: 40%;
      animation: orb-drift-3 14s ease-in-out infinite;
    }

    :global(.dark) .hero-orb-1 { background: rgba(34, 211, 238, 0.1); }
    :global(.dark) .hero-orb-2 { background: rgba(103, 232, 249, 0.07); }
    :global(.dark) .hero-orb-3 { background: rgba(34, 211, 238, 0.06); }

    @keyframes orb-drift-1 {
      0%, 100% { transform: translate(0, 0) scale(1); }
      33% { transform: translate(-60px, 40px) scale(1.1); }
      66% { transform: translate(30px, -30px) scale(0.95); }
    }

    @keyframes orb-drift-2 {
      0%, 100% { transform: translate(0, 0) scale(1); }
      33% { transform: translate(50px, -50px) scale(1.15); }
      66% { transform: translate(-40px, 20px) scale(0.9); }
    }

    @keyframes orb-drift-3 {
      0%, 100% { transform: translate(0, 0) scale(1); }
      50% { transform: translate(-80px, 60px) scale(1.2); }
    }

    @media (prefers-reduced-motion: reduce) {
      .hero-orb { animation: none; }
    }
  </style>

  <!-- Projects Section -->
  <section
    id="projects"
    class="snap-section"
    aria-labelledby="projects-heading"
  >
    <!-- Header row — constrained to content width -->
    <div class="w-full max-w-content mx-auto px-6 sm:px-10 flex items-center justify-between mb-14 reveal">
      <h2
        id="projects-heading"
        class="font-display text-heading"
      >
        Selected Work
      </h2>
      <div class="flex items-center gap-3">
        <button
          id="slider-prev"
          aria-label="Previous project"
          class="magnetic w-11 h-11 flex items-center justify-center rounded-full border transition-all duration-200 disabled:opacity-30 disabled:cursor-not-allowed hover:border-[var(--color-accent)]"
          style="border-color: var(--color-border); color: var(--color-text-muted);"
        >
          <svg class="magnetic-inner w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M19 12H5M12 19l-7-7 7-7" />
          </svg>
        </button>
        <button
          id="slider-next"
          aria-label="Next project"
          class="magnetic w-11 h-11 flex items-center justify-center rounded-full border transition-all duration-200 disabled:opacity-30 disabled:cursor-not-allowed hover:border-[var(--color-accent)]"
          style="border-color: var(--color-border); color: var(--color-text-muted);"
        >
          <svg class="magnetic-inner w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Scrollable slider track — left padding matches content, bleeds right -->
    <div
      id="slider-track"
      class="w-full reveal flex gap-8 overflow-x-auto scroll-smooth pb-4 select-none"
      style="padding-left: max(1.5rem, calc((100vw - 72rem) / 2 + 2.5rem));"
      role="region"
      aria-label="Project carousel"
      tabindex="0"
      style="cursor: grab; scroll-snap-type: x mandatory; -ms-overflow-style: none; scrollbar-width: none;"
    >
      {projects.map((project, i) => (
        <div
          class="flex-shrink-0 w-[85vw] sm:w-[60vw] md:w-[45vw] lg:w-[38vw]"
          style="scroll-snap-align: start;"
          role="group"
          aria-roledescription="slide"
          aria-label={`${i + 1} of ${projects.length}: ${project.data.title}`}
        >
          <ProjectCard
            title={project.data.title}
            description={project.data.description}
            image={project.data.image}
            tags={project.data.tags}
            slug={project.id}
          />
        </div>
      ))}
      <!-- Spacer so last card doesn't sit flush against edge -->
      <div class="flex-shrink-0 w-6 sm:w-10" aria-hidden="true"></div>
    </div>

    <!-- Progress bar — constrained to content width -->
    <div class="w-full max-w-content mx-auto px-6 sm:px-10 mt-10">
      <div class="h-0.5 rounded-full overflow-hidden" style="background-color: var(--color-border);">
        <div
          id="slider-progress"
          class="h-full rounded-full transition-all duration-300 ease-out"
          style="background-color: var(--color-accent); width: 33%;"
        ></div>
      </div>
    </div>

    <!-- Progress bar -->
    <div class="max-w-content mx-auto px-6 sm:px-10 mt-8">
      <div class="h-0.5 rounded-full overflow-hidden" style="background-color: var(--color-border);">
        <div
          id="slider-progress"
          class="h-full rounded-full transition-all duration-300 ease-out"
          style="background-color: var(--color-accent); width: 0%;"
        ></div>
      </div>
    </div>
  </section>

  <style>
    #slider-track::-webkit-scrollbar {
      display: none;
    }
  </style>

  <script define:vars={{ totalProjects: projects.length }}>
    const track = document.getElementById('slider-track');
    const prev = document.getElementById('slider-prev');
    const next = document.getElementById('slider-next');
    const progress = document.getElementById('slider-progress');
    const slides = track.querySelectorAll('[role="group"]');

    function getActiveIndex() {
      const slideWidth = slides[0].offsetWidth + 32;
      return Math.round(track.scrollLeft / slideWidth);
    }

    function updateUI() {
      const idx = getActiveIndex();
      const maxScroll = track.scrollWidth - track.clientWidth;
      const scrollPercent = maxScroll > 0 ? (track.scrollLeft / maxScroll) * 100 : 0;
      progress.style.width = `${Math.max(scrollPercent, (1 / totalProjects) * 100)}%`;
      prev.disabled = idx === 0;
      next.disabled = idx >= totalProjects - 1;
    }

    function scrollToSlide(index) {
      const slideWidth = slides[0].offsetWidth + 32;
      track.scrollTo({ left: index * slideWidth, behavior: 'smooth' });
    }

    prev.addEventListener('click', () => {
      const idx = getActiveIndex();
      if (idx > 0) scrollToSlide(idx - 1);
    });

    next.addEventListener('click', () => {
      const idx = getActiveIndex();
      if (idx < totalProjects - 1) scrollToSlide(idx + 1);
    });

    track.addEventListener('scroll', updateUI, { passive: true });

    // Mouse drag to scroll
    let isDragging = false;
    let hasDragged = false;
    let startX = 0;
    let scrollStart = 0;

    track.addEventListener('mousedown', (e) => {
      isDragging = true;
      hasDragged = false;
      startX = e.pageX;
      scrollStart = track.scrollLeft;
      track.style.scrollSnapType = 'none';
      track.style.scrollBehavior = 'auto';
      track.style.cursor = 'grabbing';
    });

    document.addEventListener('mousemove', (e) => {
      if (!isDragging) return;
      e.preventDefault();
      const delta = e.pageX - startX;
      if (Math.abs(delta) > 3) hasDragged = true;
      track.scrollLeft = scrollStart - delta;
    });

    document.addEventListener('mouseup', () => {
      if (!isDragging) return;
      isDragging = false;
      track.style.scrollSnapType = 'x mandatory';
      track.style.scrollBehavior = 'smooth';
      track.style.cursor = 'grab';
      // Snap to nearest slide
      const idx = getActiveIndex();
      scrollToSlide(idx);
    });

    // Prevent click on links after drag
    track.addEventListener('click', (e) => {
      if (hasDragged) {
        e.preventDefault();
        e.stopPropagation();
      }
    }, true);

    // Prevent image drag interfering
    track.addEventListener('dragstart', (e) => e.preventDefault());

    // Keyboard navigation
    track.addEventListener('keydown', (e) => {
      const idx = getActiveIndex();
      if (e.key === 'ArrowLeft' && idx > 0) {
        e.preventDefault();
        scrollToSlide(idx - 1);
      } else if (e.key === 'ArrowRight' && idx < totalProjects - 1) {
        e.preventDefault();
        scrollToSlide(idx + 1);
      }
    });

    updateUI();
  </script>

  <!-- Contact CTA -->
  <section
    class="snap-section border-t"
    style="border-color: var(--color-border);"
  >
    <div class="max-w-content mx-auto px-6 sm:px-10 text-center reveal-stagger reveal">
      <h2 class="reveal-child font-display text-display">
        Let's work together
      </h2>
      <p
        class="reveal-child mt-6 font-body text-body-lg max-w-xl mx-auto leading-relaxed"
        style="color: var(--color-text-muted);"
      >
        I'm always open to new opportunities and collaborations.
      </p>
      <div class="reveal-child mt-12">
        <a
          href="mailto:hello@example.com"
          class="magnetic btn-glow inline-flex items-center px-10 py-4 font-body text-body font-medium rounded-button transition-colors"
          style={`
            background-color: var(--color-accent);
            color: var(--color-text-inverse);
          `}
        >
          <span class="magnetic-inner">Get in touch</span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
